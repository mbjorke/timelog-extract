# Copy to .env and fill in real values

# Admin access (protect this key carefully)
ADMIN_API_KEY=change-me-admin-key-min-32-chars

# Your platform's authoritative name servers
NAMESERVER1=ns1.yourdomain.ax
NAMESERVER2=ns2.yourdomain.ax

# Cloudflare (for DNS zone hosting)
# Create an API token with Zone:Edit permissions
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# .ax Registry credentials
REGISTRY_API_URL=https://registry.ax/api
REGISTRY_API_KEY=
REGISTRY_RESELLER_ID=

# Database (SQLite default, swap to postgres:// for production)
DATABASE_URL=sqlite:///./ax_admin.db

# Secret for signing (32+ chars)
SECRET_KEY=change-me-secret-key-min-32-chars
