# Copy to .env.briox (gitignored). Load before running briox_connection_test.py:
#   set -a && source .env.briox && set +a && python3 briox_connection_test.py --token-only

# Application Token — Admin → Users → marcus.bjorke@blueberry.ax → Application Token
# Integration: **Blueberry Maybe** (NOT Briox Connect)
BRIOX_AUTH_TOKEN=

# Briox account ID (clientid) — Finnish portal
BRIOX_COMPANY_ID=35826158

# Finnish API (default in script if unset)
BRIOX_API_BASE=https://api-fi.briox.services/v2

# After first successful /token, optionally store for --refresh-only:
# BRIOX_ACCESS_TOKEN=
# BRIOX_REFRESH_TOKEN=
