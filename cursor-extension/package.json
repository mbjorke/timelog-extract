{
  "name": "timelog-extract-cursor",
  "displayName": "Timelog Extract",
  "description": "Automatic local timereporting setup and report runner.",
  "version": "0.1.0",
  "publisher": "timelog-extract",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:timelogExtract.openWizard",
    "onCommand:timelogExtract.openWizardBrowserPreview",
    "onCommand:timelogExtract.quickStart",
    "onCommand:timelogExtract.runToday",
    "onCommand:timelogExtract.runRange",
    "onCommand:timelogExtract.openOutputFolder"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "timelogExtract.openWizard",
        "title": "Timelog: Open Setup Wizard"
      },
      {
        "command": "timelogExtract.openWizardBrowserPreview",
        "title": "Timelog: Open Setup Wizard (Browser Preview)"
      },
      {
        "command": "timelogExtract.quickStart",
        "title": "Timelog: Quick Start"
      },
      {
        "command": "timelogExtract.runToday",
        "title": "Timelog: Run Report (Today)"
      },
      {
        "command": "timelogExtract.runRange",
        "title": "Timelog: Run Report (Date Range)"
      },
      {
        "command": "timelogExtract.openOutputFolder",
        "title": "Timelog: Open Output Folder"
      }
    ],
    "configuration": {
      "title": "Timelog Extract",
      "properties": {
        "timelogExtract.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Python executable used to run timelog_extract.py."
        },
        "timelogExtract.projectsConfig": {
          "type": "string",
          "default": "${workspaceFolder}/timelog_projects.json",
          "description": "Path to project config JSON."
        },
        "timelogExtract.worklogPath": {
          "type": "string",
          "default": "${workspaceFolder}/TIMELOG.md",
          "description": "Path to worklog file."
        },
        "timelogExtract.includeUncategorized": {
          "type": "boolean",
          "default": false,
          "description": "Include uncategorized events in report."
        },
        "timelogExtract.generatePdf": {
          "type": "boolean",
          "default": true,
          "description": "Generate PDF when running from extension commands."
        },
        "timelogExtract.chromeSource": {
          "type": "string",
          "enum": ["on", "off"],
          "default": "on",
          "description": "Enable/disable Chrome source."
        },
        "timelogExtract.mailSource": {
          "type": "string",
          "enum": ["auto", "on", "off"],
          "default": "auto",
          "description": "Apple Mail source mode."
        },
        "timelogExtract.githubSource": {
          "type": "string",
          "enum": ["auto", "on", "off"],
          "default": "auto",
          "description": "GitHub source mode."
        },
        "timelogExtract.screenTime": {
          "type": "string",
          "enum": ["auto", "on", "off"],
          "default": "auto",
          "description": "Screen Time source mode."
        },
        "timelogExtract.githubUser": {
          "type": "string",
          "default": "",
          "description": "Optional GitHub login for public activity source."
        },
        "timelogExtract.consentAccepted": {
          "type": "boolean",
          "default": false,
          "description": "Whether consent for local source scanning has been accepted for this workspace."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p ."
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.7.2"
  }
}
