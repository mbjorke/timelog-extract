{
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "~/.gittan",
        "~/.npm",
        "~/.cache/pip",
        "~/Library/Caches/pip"
      ],
      "denyWrite": [
        "timelog_projects.json",
        "TIMELOG.md",
        "private",
        "~/.gittan/timelog_projects.json"
      ]
    },
    "credentials": {
      "files": [
        { "path": "~/.ssh", "mode": "deny" },
        { "path": "~/.aws/credentials", "mode": "deny" }
      ]
    },
    "network": {
      "allowedDomains": [
        "pypi.org",
        "files.pythonhosted.org",
        "registry.npmjs.org",
        "github.com",
        "api.github.com",
        "codeload.github.com",
        "objects.githubusercontent.com"
      ]
    },
    "excludedCommands": [
      "gh *"
    ]
  }
}
